{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AllowCloudTrailWrite",
            "Effect": "Allow",
            "Principal": {
                "Service": "cloudtrail.amazonaws.com"
            },
            "Action": "s3:PutObject",
            "Resource": "arn:aws:s3:::sanmi-central-log-archive/*",
            "Condition": {
                "StringEquals": {
                    "aws:SourceOrgID": "o-0scg53y7o1"
                    
                }
            }
        }
    ]
}