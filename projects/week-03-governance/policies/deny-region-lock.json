{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyAllOutsideHomeRegion",
      "Effect": "Deny",
      "NotAction": [
        "iam:*",
        "route53:*",
        "budget:*",
        "support:*",
        "organizations:*"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotEquals": {
          "aws:RequestedRegion": "us-east-2"
        }
      }
    }
  ]
}